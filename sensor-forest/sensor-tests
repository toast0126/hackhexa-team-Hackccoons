bool luz;
bool movimiento;
bool peligro;

// Caso A (ejemplo)
luz = false;
movimiento = true;

// Evaluación
if (luz == false && movimiento == true) {
    peligro = true;
} else if (luz == true && movimiento == false) {
    peligro = false;
} else {
    peligro = false; // por defecto seguro
}

// Resultado
if (peligro == true) {
    print("SOSPECHOSO");
} else {
    print("SEGURO");
}